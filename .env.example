# Configuração do Supabase
# NUNCA commite este arquivo preenchido. Mantenha apenas no ambiente local.
# Se as chaves forem vazadas/committadas por engano, rotacione-as imediatamente
# no painel do Supabase: Project Settings → API.

VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key-aqui

# Futuro: quando as Publishable keys estiverem estáveis, descomente e use esta:
# VITE_SUPABASE_PUBLISHABLE_KEY=sua-publishable-key-aqui

# Apenas para backend/scripts. NUNCA use esta chave no frontend!
SUPABASE_SERVICE_ROLE_KEY=sua-secret-key-aqui

# Modo mock para desenvolvimento (localStorage em vez do Supabase)
# Use apenas em ambiente local. Em produção deve ser 'false' ou omitido.
VITE_MODO_MOCK=false
